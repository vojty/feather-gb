{
  "name": "feather-gb",
  "homepage": "https://vojty.github.io/feather-gb/",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:gb && pnpm run build:debugger && rimraf public && vite build && gzip --keep --recursive public",
    "build:gb": "wasm-pack build --release ./gb-web --target bundler",
    "build:debugger": "wasm-pack build --release ./debugger-web --target bundler",
    "dev": "pnpm run build:gb && pnpm run build:debugger && vite dev",
    "preview": "vite preview",
    "debugger": "cargo run -p debugger --release",
    "dev-debugger": "cargo run -p debugger --profile dev-optimized",
    "desktop": "cargo run -p desktop --release",
    "tests": "cargo run -p integration-tests --release",
    "dev-tests": "cargo run -p integration-tests --profile dev-optimized",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "biome lint",
    "tsc": "tsc --noEmit",
    "validate": "pnpm run tsc && pnpm run lint"
  },
  "dependencies": {
    "@rehooks/local-storage": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.4.2",
    "svgo": "^3.3.3",
    "tailwindcss": "^3.4.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@darkobits/vite-plugin-favicons": "^0.3.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/stylis": "^4.2.7",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "fast-glob": "^3.3.3",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.3.0",
    "oxfmt": "^0.52.0",
    "postcss": "^8.5.15",
    "rehype-parse": "^9.0.1",
    "rehype-rewrite": "^4.0.4",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "unplugin-fonts": "^1.4.0",
    "vite": "^7.3.3",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plugin-wasm": "^3.5.0",
    "vite-plugin-wasm-pack": "^0.1.12"
  }
}
